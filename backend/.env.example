# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/zovu
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379

# Celery broker always uses REDIS_URL with logical DB /2 (CELERY_BROKER_URL in .env is ignored).
# Optional: separate result backend only (same /N rule, not ?db=N).
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# JWT (RS256 Asymmetric)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Squad API
SQUAD_SECRET_KEY=your_squad_secret_key
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_WEBHOOK_IP=

# External APIs
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
COHERE_API_KEY=your_cohere_api_key

# Encryption (Fernet key)
# Generate with: from cryptography.fernet import Fernet; Fernet.generate_key().decode()
FIELD_ENCRYPTION_KEY=your_fernet_key_here

# Email (SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@zovu.co
FROM_NAME=Zovu
SENDGRID_API_KEY=

# CSV data directory for seeder (absolute path to AI-engineer/data)
CSV_DATA_DIR=/app/AI-engineer/data

# Frontend URL (used in job match email deep links)
FRONTEND_URL=https://app.zovu.co

# Default admin account (created idempotently by the seeder on startup)
ADMIN_EMAIL=admin@zovu.co
ADMIN_PASSWORD=ZovuAdmin2026!
ADMIN_FULL_NAME=Admin User

# Application
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
SENTRY_DSN=
